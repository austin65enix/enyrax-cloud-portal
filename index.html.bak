<!doctype html>
<html lang="zh-Hant">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>ENYRAX Cloud Portal</title>
  <style>
    body {
      margin: 0;
      min-height: 100vh;
      display: grid;
      place-items: center;
      background: radial-gradient(circle at top, #1e2b68, #090b18 65%);
      color: #f5f0dc;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    .card {
      padding: 42px;
      border: 1px solid rgba(255, 215, 120, .28);
      border-radius: 24px;
      background: rgba(10, 13, 30, .72);
      box-shadow: 0 24px 80px rgba(0,0,0,.45);
      text-align: center;
      max-width: 720px;
    }
    h1 {
      margin: 0 0 12px;
      font-size: 42px;
      letter-spacing: .08em;
    }
    p {
      margin: 8px 0;
      color: rgba(245,240,220,.78);
      font-size: 18px;
    }
    .tag {
      margin-top: 22px;
      color: #73f4df;
      font-weight: 700;
    }
  </style>
</head>
<body>
  <main class="card">
    <h1>ENYRAX</h1>
    <p>Cloud Demo Portal</p>
    <p>SOC × ServiceOps × ProjectOps × AI Decision Engine</p>
    <div class="tag">Akamai Tokyo 3 / Ubuntu 24.04 / Nginx Online</div>
  </main>
</body>
</html>
